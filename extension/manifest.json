{
  "manifest_version": 3,
  "name": "slopstop",
  "version": "1.3.0",
  "description": "Sniffs out AI slop in your feed. Heuristic scoring for posts and comments on LinkedIn and Substack.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://*/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "dist/index.html",
    "default_title": "slopstop",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "css": ["content/styles.css"],
      "js": ["content/heuristics.js", "content/badge.js", "content/linkedin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://substack.com/*", "https://*.substack.com/*"],
      "css": ["content/styles.css"],
      "js": ["content/heuristics.js", "content/badge.js", "content/substack.js"],
      "run_at": "document_idle"
    }
  ]
}
