{
  "name": "slopstop-extension",
  "private": true,
  "version": "1.3.0",
  "type": "module",
  "scripts": {
    "build:clean": "rm -rf dist",
    "build:popup": "vite build --config vite.popup.config.ts",
    "build:background": "vite build --config vite.background.config.ts",
    "build": "npm run build:clean && npm run build:popup && npm run build:background",
    "dev": "vite build --watch --config vite.popup.config.ts"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.300",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
